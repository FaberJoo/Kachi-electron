{
  "name": "kachi",
  "version": "0.1.0",
  "description": "A local-first markdown editor app for macOS, Windows, and Linux.",
  "packageManager": "pnpm@9.15.4",
  "main": "main.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "author": "",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -k \"pnpm dev:web\" \"pnpm dev:electron\"",
    "start": "electron .",
    "dev:web": "vite",
    "dev:electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "build:web": "vite build",
    "build": "pnpm build:web",
    "preview:web": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "pack": "electron-builder --dir",
    "dist": "pnpm build:web && electron-builder",
    "dist:mac": "pnpm build:web && electron-builder --mac dmg",
    "dist:win": "pnpm build:web && electron-builder --win nsis",
    "dist:linux": "pnpm build:web && electron-builder --linux AppImage deb"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "^0.17.6",
    "@tiptap/pm": "^2.6.6",
    "@tiptap/react": "^2.6.6",
    "@tiptap/starter-kit": "^2.6.6",
    "@xyflow/react": "^12.3.6",
    "@tanstack/react-table": "^8.20.5",
    "better-sqlite3": "^11.7.0",
    "hyperformula": "^3.0.0",
    "minisearch": "^7.1.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.1",
    "unified": "^11.0.5",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/node": "^22.18.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.42.0",
    "@typescript-eslint/parser": "^8.42.0",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^24.13.3",
    "eslint": "^9.34.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^5.2.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.2",
    "vite": "^7.1.2",
    "vitest": "^3.2.4",
    "wait-on": "^8.0.1",
    "jsdom": "^24.1.3"
  },
  "build": {
    "appId": "com.kachi.app",
    "productName": "Kachi",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "dist/**",
      "package.json"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Utility"
    }
  }
}
